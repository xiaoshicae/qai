{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QAI",
  "version": "0.1.7",
  "identifier": "com.qai.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QAI - AI-Powered API Testing",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; script-src 'self' 'unsafe-inline' 'unsafe-eval' tauri: asset:; style-src 'self' 'unsafe-inline' tauri: asset:; img-src 'self' tauri: asset: data: blob:; media-src 'self' tauri: asset: data: blob:; font-src 'self' tauri: asset: data:; connect-src 'self' tauri: asset: https: wss:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "msi"],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "background": "images/dmg-background.png"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyRjJEMDBENDMwQzM5QTEKUldTaE9ReEREZER5MHZaelhuRVpxZE9pOWVuZW5pcEEzaXVCRmwrUElEdHdtdGh0OEFCdWVzNFcK",
      "endpoints": [
        "https://github.com/xiaoshicae/qai/releases/latest/download/latest.json"
      ]
    }
  }
}
